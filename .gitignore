## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.user
*.userosscache
*.suo
*.userprefs
*.vspscc
*.vssscc

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
arm/
arm64/
bld/
[Bb]in/
[Oo]bj/

# Visual Studio files
.vs/
.vscode/
*.vcxproj.filters
*.vcxproj.user
*.vcxproj.filters.user

# ReSharper is a .NET coding assistant
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# Rider IDE
.idea/

# NuGet Packages
packages/
*.nupkg
*.nuspec
nuget.exe

# .NET Core
project.lock.json
project.assets.json
*.csproj.nuget.dgspec.json
*.csproj.nuget.g.props
*.csproj.nuget.g.targets

# MSBuild
*.msbuild.log
*.binlog

# Azure
*.publishsettings

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store

# Linux
*.swp
*.swo

# Backup & temp files
*~
*.bak
*.tmp

# Logs
*.log

# Coverage reports (e.g., from Coverlet)
coverage/
coverage.json
coverage.opencover.xml
coverage.cobertura.xml

# Test results
TestResults/
*.trx
*.xml # Optional

# Local settings (e.g., launchSettings.json secrets)
Properties/launchSettings.json

# Optional: ignore local .NET tools manifest if you don't want to share it
# .config/dotnet-tools.json
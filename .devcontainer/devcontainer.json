{
    "name": "LeetCode Cpp Development",
    "build": {
        "dockerfile": "Dockerfile",
        "context": ".."
    },
    "features": {
        "ghcr.io/devcontainers/features/node:1": {
            "version": "lts"
        }
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "LeetCode.vscode-leetcode",
                "EditorConfig.EditorConfig",
                "ms-vscode.cpptools"
            ],
            "settings": {
                "leetcode.endpoint": "leetcode",
                "leetcode.defaultLanguage": "cpp",
                "leetcode.workspaceFolder": "/workspaces/CodingPractice/Solutions"
            }
        }
    },
    "postCreateCommand": "echo 'Dev container ready for LeetCode Cpp!'",
    "remoteUser": "vscode"
}

{
    "name": "LeetCode C# Development",
    "build": {
        "dockerfile": "Dockerfile",
        "context": ".."
    },
    "features": {
        "ghcr.io/devcontainers/features/node:1": {
            "version": "lts"
        }
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-dotnettools.csharp",
                "LeetCode.vscode-leetcode",
                "EditorConfig.EditorConfig"
            ],
            "settings": {
                "leetcode.endpoint": "leetcode",
                "leetcode.defaultLanguage": "csharp",
                "leetcode.workspaceFolder": "/workspaces/CodingPractice/Solutions"
            }
        }
    },
    "postCreateCommand": "dotnet --version && echo 'Dev container ready for LeetCode C#!'",
    "remoteUser": "vscode"
}
